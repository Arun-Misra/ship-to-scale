# Gemini / Google AI
GEMINI_API_KEY=
# Model ID — check exact name at https://ai.google.dev/gemini-api/docs/models
# Examples: gemma-3-27b-it | gemma-4-31b-it | gemini-2.0-flash
GEMINI_MODEL=gemma-4-31b-it

# Appwrite
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DB_ID=
APPWRITE_COLLECTION_WORKSPACES=workspaces
APPWRITE_COLLECTION_CONNECTIONS=connections
APPWRITE_COLLECTION_SEMANTIC=semantic_definitions
APPWRITE_COLLECTION_INVESTIGATIONS=investigations
APPWRITE_COLLECTION_SLACK_INSTALLATIONS=slack_installations

# Slack
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# App
DEMO_DB_PATH=data/demo.duckdb
FRONTEND_URL=http://localhost:5174

# DuckDB sandbox defaults
SANDBOX_STATEMENT_TIMEOUT_SECONDS=8
SANDBOX_ROW_CAP=5000
AGENT_STEP_BUDGET=8
AGENT_RETRY_BUDGET_PER_STEP=2
